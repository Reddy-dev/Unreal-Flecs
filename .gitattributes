# Normalize line endings to LF on commit, checkout as-is on all platforms
* text=auto eol=lf

# Source files - always LF
*.h text eol=lf
*.hpp text eol=lf
*.cpp text eol=lf
*.c text eol=lf
*.cs text eol=lf
*.inl text eol=lf
*.ini text eol=lf
*.json text eol=lf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files - no line ending conversion
*.uasset binary
*.umap binary
*.png binary
*.jpg binary
*.ico binary
*.lib binary
*.dll binary
*.exe binary
